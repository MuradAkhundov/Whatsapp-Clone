<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.fragments.StatusFragment"
    android:background="#EEECEC"
    >
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="#Fff">


        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">



            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/roundedImage"
                android:layout_marginTop="@dimen/_7sdp"
                android:layout_marginStart="@dimen/_3sdp"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:src="@drawable/person_male"
                app:riv_oval="true"
                android:scaleType="centerCrop"/>
            
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/image_profile"
                android:layout_alignBottom="@id/roundedImage"
                android:layout_alignEnd="@id/roundedImage"
                android:background="@color/transparent"
                android:layout_marginEnd="@dimen/_1sdp"/>

            
        </RelativeLayout>

        <LinearLayout
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">



                <TextView
                    android:id="@+id/userNameText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="My Status"/>


                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_12ssp"
                    android:textColor="#2E2E2E"
                    android:text="04/09/2023"/>




            </LinearLayout>

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_12ssp"
                android:textColor="#2E2E2E"
                android:text="Tap to add status"/>

        </LinearLayout>




    </LinearLayout>

</LinearLayout>